{
  "package": {
    "productName": "DiscoCast Visualizer",
    "version": "0.1.0"
  },
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "execute": true,
        "sidecar": false
      },
      "window": {
        "setFullscreen": true
      }
    },
    "bundle": {
      "active": true,
      "category": "Music",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns"
      ],
      "identifier": "app.discocast.visualizer",
      "macOS": {
        "entitlements": "entitlements.plist"
      },
      "targets": ["app"]
    },
    "windows": [{
      "title": "DiscoCast Visualizer",
      "width": 1200,
      "height": 800,
      "minWidth": 800,
      "minHeight": 600,
      "center": true
    }]
  }
}
